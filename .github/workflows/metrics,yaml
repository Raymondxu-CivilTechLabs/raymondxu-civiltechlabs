name: Metrics
on:
  schedule: [{cron: "0 0 * * *"}] # 每天自动更新一次
  workflow_dispatch:
jobs:
  github-metrics:
    runs-on: ubuntu-latest
    steps:
      - uses: lowlighter/metrics@latest
        with:
          token: ${{ secrets.METRICS_TOKEN }} # 需要你在GitHub设置一个Token
          user: 你的GitHub用户名
          template: classic
          base: header, repositories
          config_timezone: Europe/Rome
          plugin_languages: yes
          plugin_languages_ignored: html, css, tex # 隐藏掉杂乱的辅助语言
          plugin_habits: yes # 展示你的科研/编码习惯
          plugin_habits_from: 200